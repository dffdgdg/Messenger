<UserControl x:Name="Root"
			 xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vmDialog="using:MessengerDesktop.ViewModels.Dialog"
			 xmlns:conv="clr-namespace:MessengerDesktop.Converters;assembly=MessengerDesktop"
			 xmlns:controls="using:MessengerDesktop.Views.Controls"
			 x:Class="MessengerDesktop.Views.ChatEditDialog"
			 x:DataType="vmDialog:ChatEditDialogViewModel"
			 mc:Ignorable="d"
			 d:DesignWidth="450" d:DesignHeight="800">

	<Border Classes="DialogContainer" Width="450" MaxHeight="800"
			Background="{DynamicResource SecondaryBG}">
		<Grid RowDefinitions="Auto,*,Auto">
			<StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,16">
				<TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="20"/>

				<Grid ColumnDefinitions="Auto,*" Margin="0,8,0,0">
					<Grid Grid.Column="0" Width="80" Height="80" Margin="0,0,16,0">
						<controls:AvatarControl Classes="XLarge"
												ImageBitmap="{Binding AvatarPreview}"
												FallbackIcon="{StaticResource GroupIcon}"
												ShowOnlineIndicator="False"
												PlaceholderBackground="{DynamicResource SurfaceVariant}"
												PlaceholderForeground="White"/>
						<Button Classes="IconButton" Width="28" Height="28" CornerRadius="14"
								HorizontalAlignment="Right" VerticalAlignment="Bottom"
								Command="{Binding SelectAvatarCommand}"
								ToolTip.Tip="Выбрать аватар">
							<Path Data="{StaticResource CameraIcon}"
								  Width="14" Height="14" Stretch="Uniform"
								  Fill="{DynamicResource TextPrimary}"/>
						</Button>
						<Button Classes="IconButton" Width="20" Height="20" CornerRadius="10"
								HorizontalAlignment="Right" VerticalAlignment="Top"
								Margin="0,-4,-4,0"
								Command="{Binding ClearAvatarCommand}"
								IsVisible="{Binding AvatarPreview, Converter={x:Static ObjectConverters.IsNotNull}}"
								ToolTip.Tip="Удалить аватар">
							<Path Data="{StaticResource CloseIcon}"
								  Width="8" Height="8" Stretch="Uniform"
								  Fill="{DynamicResource TextSecondary}"/>
						</Button>
					</Grid>

					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
						<TextBlock Text="Название группы" FontWeight="DemiBold" FontSize="12"
								   Foreground="{DynamicResource TextSecondary}"/>
						<TextBox Text="{Binding Name}" Watermark="Введите название..."
								 Classes="Input" MaxLength="100"/>
					</StackPanel>
				</Grid>
			</StackPanel>

			<ScrollViewer Grid.Row="1"
						  VerticalScrollBarVisibility="Auto"
						  Classes="ThinScrollbar">
				<StackPanel Spacing="12" Margin="0,0,0,8">

					<TextBlock Text="УПРАВЛЕНИЕ" Classes="CategoryHeader" Margin="0"/>

					<Border Classes="Section" Padding="4">
						<StackPanel Spacing="0">
							<Button Classes="MemberItem"
									Command="{Binding ManageParticipantsCommand}"
									Padding="12,10">
								<Grid ColumnDefinitions="Auto,*,Auto,Auto">
									<PathIcon Data="{StaticResource GroupIcon}"
											  Width="20" Height="20"/>
									<TextBlock Grid.Column="1" Text="Участники"
											   FontWeight="SemiBold" FontSize="14"
											   VerticalAlignment="Center" Margin="12,0,0,0"/>
									<Border Grid.Column="2" Classes="CountBadge"
											VerticalAlignment="Center" Margin="0,0,10,0">
										<TextBlock Text="{Binding ParticipantsCount}"/>
									</Border>
									<Path Grid.Column="3"
										  Data="{StaticResource ChevronRightIcon}"
										  Width="12" Height="12" Stretch="Uniform"
										  Fill="{DynamicResource TextMuted}"
										  VerticalAlignment="Center"/>
								</Grid>
							</Button>

							<Border Height="1" Background="{DynamicResource BorderDefault}"
									Margin="40,0,12,0"/>

							<Button Classes="MemberItem"
									Command="{Binding ManageAdminsCommand}"
									Padding="12,10">
								<Grid ColumnDefinitions="Auto,*,Auto,Auto">
									<PathIcon Data="{StaticResource ShieldIcon}"
											  Width="20" Height="20"/>
									<TextBlock Grid.Column="1" Text="Администраторы"
											   FontWeight="SemiBold" FontSize="14"
											   VerticalAlignment="Center" Margin="12,0,0,0"/>
									<Border Grid.Column="2" Classes="CountBadge"
											VerticalAlignment="Center" Margin="0,0,10,0">
										<TextBlock Text="{Binding AdminsCount}"/>
									</Border>
									<Path Grid.Column="3"
										  Data="{StaticResource ChevronRightIcon}"
										  Width="12" Height="12" Stretch="Uniform"
										  Fill="{DynamicResource TextMuted}"
										  VerticalAlignment="Center"/>
								</Grid>
							</Button>
						</StackPanel>
					</Border>

					<Border CornerRadius="8" Padding="12,8"
							Background="{DynamicResource ThirdBG}"
							BorderThickness="1"
							BorderBrush="{DynamicResource BorderDefault}">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<PathIcon Data="{StaticResource UserRoleIcon}"
									  Width="16" Height="16"/>
							<TextBlock Grid.Column="1" Text="Ваша роль"
									   FontSize="13" Margin="10,0,0,0"
									   Foreground="{DynamicResource TextSecondary}"
									   VerticalAlignment="Center"/>
							<Border Grid.Column="2"
									Background="{DynamicResource AccentMuted}"
									CornerRadius="6" Padding="10,3">
								<TextBlock Text="{Binding CurrentUserRole}"
										   FontSize="12" FontWeight="SemiBold"
										   Foreground="{DynamicResource Accent}"/>
							</Border>
						</Grid>
					</Border>

					<StackPanel Spacing="12" IsVisible="{Binding !IsNewChat}">
						<TextBlock Text="НАСТРОЙКИ" Classes="CategoryHeader" Margin="0,8,0,0"/>

						<Border Classes="Section" Padding="4">
							<Border Padding="12,10" CornerRadius="8">
								<Grid ColumnDefinitions="Auto,*,Auto">
									<PathIcon Data="{StaticResource HistoryIcon}"
											  Width="20" Height="20"/>
									<StackPanel Grid.Column="1" VerticalAlignment="Center"
												Margin="12,0,12,0" Spacing="2">
										<TextBlock Text="История для новых участников"
												   FontWeight="SemiBold" FontSize="14"/>
									</StackPanel>
									<ToggleSwitch Grid.Column="2"
												  VerticalAlignment="Center"
												  OnContent="" OffContent=""
												  Margin="0,0,-8,0"/>
								</Grid>
							</Border>
						</Border>
					</StackPanel>

					<Border CornerRadius="12" Padding="4"
							Background="{DynamicResource ThirdBG}"
							BorderThickness="1" Margin="0,8"
							BorderBrush="{DynamicResource DangerBorderBrush}"
							IsVisible="{Binding !IsNewChat}">
						<Button Classes="MemberItem"
								Padding="12,10">
							<Grid ColumnDefinitions="Auto,*,Auto">
								<PathIcon Data="{StaticResource DeleteIcon}"
										  Width="20" Height="20"
										  Foreground="{DynamicResource DangerBrush}"/>
								<StackPanel Grid.Column="1" VerticalAlignment="Center"
											Margin="12,0,0,0" Spacing="2">
									<TextBlock Text="Удалить группу"
											   FontWeight="SemiBold" FontSize="14"
											   Foreground="{DynamicResource DangerBrush}"/>
								</StackPanel>
								<Path Grid.Column="2"
									  Data="{StaticResource ChevronRightIcon}"
									  Width="12" Height="12" Stretch="Uniform"
									  Fill="{DynamicResource DangerBrush}" Opacity="0.6"
									  VerticalAlignment="Center"/>
							</Grid>
						</Button>
					</Border>

				</StackPanel>
			</ScrollViewer>

			<StackPanel Grid.Row="2" Spacing="12" Margin="0,16,0,0">
				<TextBlock Text="{Binding ErrorMessage}"
						   Foreground="{DynamicResource ErrorColor}" TextWrapping="Wrap"
						   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
				<TextBlock Text="{Binding SuccessMessage}"
						   Foreground="{DynamicResource SuccessColor}" TextWrapping="Wrap"
						   IsVisible="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
					<Button Content="Отмена" Classes="DialogOutline"
							Command="{Binding CancelCommand}" MinWidth="100"/>
					<Button Classes="DialogAccent"
							Content="{Binding IsNewChat, Converter={conv:Converter Name=BoolToString}, ConverterParameter='Создать|Сохранить'}"
							Command="{Binding SaveCommand}"
							IsEnabled="{Binding CanSave}" MinWidth="100"/>
				</StackPanel>
			</StackPanel>
		</Grid>
	</Border>
</UserControl>