<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:shared="using:MessengerDesktop.Views.Controls.Shared"
			 xmlns:parts="using:MessengerDesktop.Views.Chat.MessageParts.Shared"
			 xmlns:vmChat="using:MessengerDesktop.ViewModels.Chat"
			 x:Class="MessengerDesktop.Views.Chat.MessageParts.VoiceMessagePart"
			 x:DataType="vmChat:MessageViewModel"
			 x:Name="VoiceRoot">

	<Border Classes="VoicePlayerContainer"
			IsVisible="{Binding ShowVoiceMessage}">
		<StackPanel Spacing="0">

			<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">

				<Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoicePlayBtn"
						Width="46" Height="46"
						Command="{Binding PlayVoiceCommand}"
						IsVisible="{Binding ShowPlayButton}"
						ToolTip.Tip="Воспроизвести">
					<PathIcon Data="{StaticResource PlayIcon}" Width="20" Height="20"/>
				</Button>

				<Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoicePlayBtn"
						Width="46" Height="46"
						Command="{Binding PauseVoiceCommand}"
						IsVisible="{Binding ShowPauseButton}"
						ToolTip.Tip="Пауза">
					<PathIcon Data="{StaticResource PauseIcon}" Width="20" Height="20"/>
				</Button>

				<Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoicePlayBtn"
						Width="46" Height="46"
						Command="{Binding PlayVoiceCommand}"
						IsVisible="{Binding ShowResumeButton}"
						ToolTip.Tip="Продолжить">
					<PathIcon Data="{StaticResource PlayIcon}" Width="20" Height="20"/>
				</Button>

				<Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoiceLoadingContainer"
						Width="46" Height="46"
						IsVisible="{Binding IsVoiceLoading}">
					<shared:CircularProgress Width="22" Height="22"
											 IsIndeterminate="True"
											 HorizontalAlignment="Center"
											 VerticalAlignment="Center"/>
				</Border>

				<Slider Grid.Row="0" Grid.Column="1"
						Classes="VoiceSlider"
						Value="{Binding VoicePositionPercent}"
						Margin="12,0,10,0"
						VerticalAlignment="Center"
						IsEnabled="{Binding IsVoicePlaying}"/>

				<Button Grid.Row="0" Grid.Column="2"
						Classes="TranscribeBtn"
						Classes.Active="{Binding IsTranscriptionExpanded}"
						Command="{Binding ToggleTranscriptionCommand}"
						IsVisible="{Binding CanTranscribe}"
						ToolTip.Tip="Расшифровка">
					<PathIcon Data="{StaticResource TranscribeIcon}"
							  Width="14" Height="14"
							  Foreground="{DynamicResource Accent}"/>
				</Button>

				<Border Grid.Row="0" Grid.Column="2"
						Width="4"
						IsVisible="{Binding !CanTranscribe}"
						IsHitTestVisible="False"/>

				<Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
					  Margin="12,2,0,0">
					<Border HorizontalAlignment="Left" Classes="VoiceTimeBadge">
						<TextBlock Classes="VoiceTime">
							<TextBlock.Text>
								<MultiBinding StringFormat="{}{0} / {1}">
									<Binding Path="VoicePositionText"/>
									<Binding Path="VoiceDurationFormatted"/>
								</MultiBinding>
							</TextBlock.Text>
						</TextBlock>
					</Border>

					<StackPanel Orientation="Horizontal"
								Spacing="3"
								HorizontalAlignment="Right"
								VerticalAlignment="Center">
						<TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}"
								   FontSize="11"
								   Foreground="{DynamicResource TextMuted}"
								   VerticalAlignment="Bottom"
								   Margin="0,0,0,1"/>
						<Path Data="{StaticResource CheckIcon}"
							  Width="14" Height="14"
							  Stretch="Uniform"
							  VerticalAlignment="Bottom"
							  Margin="2,0,0,1"
							  Classes.Read="{Binding IsRead}"
							  Classes.Unread="{Binding !IsRead}"
							  IsVisible="{Binding ShowDeliveryStatus}">
							<Path.Styles>
								<Style Selector="Path.Read">
									<Setter Property="Fill" Value="{DynamicResource Accent}"/>
								</Style>
								<Style Selector="Path.Unread">
									<Setter Property="Fill" Value="{DynamicResource TextMuted}"/>
								</Style>
							</Path.Styles>
						</Path>
					</StackPanel>
				</Grid>
			</Grid>

			<TextBlock Text="{Binding VoiceError}"
					   Classes="VoiceError"
					   IsVisible="{Binding VoiceError,
					   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

			<Border Classes="TranscriptionPanel"
					IsVisible="{Binding IsTranscriptionExpanded}">
				<StackPanel Spacing="4">

					<StackPanel Orientation="Horizontal" Spacing="6"
								IsVisible="{Binding IsTranscriptionLoading}">
						<shared:CircularProgress Width="14" Height="14" IsIndeterminate="True"/>
						<TextBlock Text="Расшифровка..."
								   FontSize="12"
								   Foreground="{DynamicResource TextMuted}"/>
					</StackPanel>

					<SelectableTextBlock Text="{Binding TranscriptionText}"
										 FontSize="13"
										 FontStyle="Italic"
										 Foreground="{DynamicResource TextPrimary}"
										 TextWrapping="Wrap"
										 LineHeight="19"
										 Opacity="0.85"
										 IsVisible="{Binding HasTranscriptionText}"/>

					<StackPanel IsVisible="{Binding IsTranscriptionFailed}" Spacing="4">
						<TextBlock Text="Не удалось расшифровать"
								   FontSize="12"
								   Foreground="{DynamicResource TextMuted}"/>
						<Button Classes="RetryTranscription"
								HorizontalAlignment="Left"
								Command="{Binding #VoiceRoot.RetryTranscriptionCommand}"
								CommandParameter="{Binding}"
								ToolTip.Tip="Повторить">
							<StackPanel Orientation="Horizontal" Spacing="4">
								<PathIcon Data="{StaticResource RefreshIcon}"
										  Width="12" Height="12"
										  Foreground="{DynamicResource Accent}"/>
								<TextBlock Text="Повторить"
										   FontSize="12"
										   Foreground="{DynamicResource Accent}"/>
							</StackPanel>
						</Button>
					</StackPanel>

					<TextBlock Text="Нажмите для расшифровки аудио"
							   FontSize="12"
							   Foreground="{DynamicResource TextMuted}"
							   FontStyle="Italic"
							   IsVisible="{Binding ShowTranscriptionPlaceholder}"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</Border>

	<UserControl.Styles>
		<Style Selector="Button.TranscribeBtn">
			<Setter Property="Width" Value="28"/>
			<Setter Property="Height" Value="28"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
			<Setter Property="Opacity" Value="0.6"/>
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
			<Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.TranscribeBtn /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
			<Setter Property="CornerRadius" Value="14"/>
		</Style>

		<Style Selector="Button.TranscribeBtn:pointerover">
			<Setter Property="Opacity" Value="1"/>
		</Style>

		<Style Selector="Button.TranscribeBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource BorderHover}"/>
		</Style>

		<Style Selector="Button.TranscribeBtn:pressed">
			<Setter Property="RenderTransform" Value="scale(0.9)"/>
		</Style>

		<Style Selector="Button.TranscribeBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource BorderDefault}"/>
		</Style>

		<Style Selector="Button.TranscribeBtn.Active">
			<Setter Property="Opacity" Value="1"/>
		</Style>

		<Style Selector="Button.TranscribeBtn.Active /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource AccentMuted}"/>
		</Style>

		<Style Selector="Button.TranscribeBtn.Active PathIcon">
			<Setter Property="Foreground" Value="{DynamicResource Accent}"/>
		</Style>

		<Style Selector="Border.TranscriptionPanel">
			<Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="10,8"/>
			<Setter Property="Margin" Value="0,6,0,0"/>
		</Style>

		<Style Selector="Button.RetryTranscription">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="6,3"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>

		<Style Selector="Button.RetryTranscription /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>

		<Style Selector="Button.RetryTranscription:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource HoverOverlay}"/>
			<Setter Property="CornerRadius" Value="6"/>
		</Style></UserControl.Styles>
</UserControl>