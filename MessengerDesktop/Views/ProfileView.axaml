<UserControl x:Name="Root"
             xmlns="https://github.com/avaloniaui"
             xmlns:controls="using:MessengerDesktop.Views.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MessengerDesktop.ViewModels"
             x:Class="MessengerDesktop.Views.ProfileView"
             x:DataType="vm:ProfileViewModel"
             Background="{DynamicResource PrimaryBG}">
	<Border Classes="PageContainer">
		<ScrollViewer VerticalScrollBarVisibility="Auto"
					  HorizontalScrollBarVisibility="Disabled"
					  Classes="ThinScrollbar">
			<Border Padding="32,24,32,56">
				<StackPanel Width="480"
							HorizontalAlignment="Center"
							Spacing="20">

					<StackPanel Spacing="4">
						<TextBlock Text="Профиль" Classes="PageTitle"/>
						<TextBlock Text="Управление личными данными и безопасностью"
								   Classes="SectionSubtitle"/>
					</StackPanel>

					<Border Classes="Section">
						<Grid ColumnDefinitions="Auto,*">
							<Panel Classes="AvatarEditContainer"
								   Width="96" Height="96"
								   Margin="0,0,4,0">

								<controls:AvatarControl Classes="XLarge"
														ImageBitmap="{Binding AvatarBitmap}"
														Source="{Binding AvatarUrl}"
														DisplayName="{Binding FullName}"
														ShowOnlineIndicator="False"/>

								<Button Classes="AvatarEditOverlay"
										Width="88" Height="88"
										CornerRadius="44"
										Command="{Binding UploadAvatarCommand}"
										ToolTip.Tip="Изменить аватар">
									<Border Classes="AvatarOverlay"
											Width="88" Height="88"
											CornerRadius="44"
											Background="#66000000">
										<PathIcon Data="{StaticResource CameraIcon}"
												  Width="24" Height="24"
												  Foreground="White"/>
									</Border>
								</Button>

								<Button Classes="AvatarDeleteBadge"
										Width="24" Height="24" CornerRadius="12"
										HorizontalAlignment="Right"
										VerticalAlignment="Top"
										Margin="0,-2,-2,0"
										Command="{Binding DeleteAvatarCommand}"
										IsVisible="{Binding HasAvatar}"
										ToolTip.Tip="Удалить аватар">
									<Path Data="{StaticResource CloseIcon}"
										  Width="9" Height="9" Stretch="Uniform"
										  Fill="White"/>
								</Button>
							</Panel>

							<StackPanel Grid.Column="1"
										VerticalAlignment="Center"
										Spacing="6"
										Margin="20,0,0,0">
								<TextBlock Text="{Binding FullName}"
										   FontSize="20"
										   FontWeight="SemiBold"
										   TextTrimming="CharacterEllipsis"/>
								<StackPanel Orientation="Horizontal" Spacing="2">
									<TextBlock Text="@"
											   Classes="TextMuted"
											   FontSize="14"/>
									<TextBlock Text="{Binding Username, FallbackValue='username'}"
											   Classes="TextSecondary"
											   FontSize="14"/>
								</StackPanel>
							</StackPanel>
						</Grid>
					</Border>

					<Border Classes="Section">
						<StackPanel Spacing="16">

							<Grid ColumnDefinitions="Auto,*,Auto">
								<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
									<PathIcon Data="{StaticResource ProfileIcon}"
											  Width="18" Height="18"
											  Foreground="{DynamicResource Accent}"/>
									<TextBlock Text="Личные данные"
											   Classes="SectionItemTitle"/>
								</StackPanel>

								<Button Grid.Column="2"
										Classes="IconButton Small"
										Command="{Binding StartEditProfileCommand}"
										IsVisible="{Binding !IsEditingProfile}"
										ToolTip.Tip="Редактировать">
									<PathIcon Data="{StaticResource EditIcon}"
											  Width="16" Height="16"
											  Foreground="{DynamicResource TextSecondary}"/>
								</Button>
							</Grid>

							<StackPanel Spacing="12" IsVisible="{Binding !IsEditingProfile}">
								<Grid RowDefinitions="Auto,Auto,Auto"
									  ColumnDefinitions="90,*"
									  RowSpacing="10">

									<TextBlock Text="Фамилия" Classes="FieldLabel" Opacity="0.7"/>
									<TextBlock Grid.Column="1"
											   Text="{Binding SurnameDisplay}"
											   Classes="FieldValue"/>

									<TextBlock Grid.Row="1" Text="Имя" Classes="FieldLabel" Opacity="0.7"/>
									<TextBlock Grid.Row="1" Grid.Column="1"
											   Text="{Binding NameDisplay}"
											   Classes="FieldValue"/>

									<TextBlock Grid.Row="2" Text="Отчество" Classes="FieldLabel" Opacity="0.7"/>
									<TextBlock Grid.Row="2" Grid.Column="1"
											   Text="{Binding MidnameDisplay}"
											   Classes="FieldValue"/>
								</Grid>
							</StackPanel>

							<StackPanel Spacing="16" IsVisible="{Binding IsEditingProfile}">

								<Border Classes="PreviewBanner">
									<Grid ColumnDefinitions="Auto,*">
										<TextBlock Text="Отображается как:"
												   Classes="TextSecondary"
												   FontSize="12"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1"
												   Text="{Binding TempFullName}"
												   FontSize="14"
												   FontWeight="Medium"
												   Margin="8,0,0,0"
												   VerticalAlignment="Center"/>
									</Grid>
								</Border>

								<Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
									<StackPanel Spacing="6">
										<TextBlock Text="Фамилия" Classes="FieldLabel" FontSize="12"/>
										<TextBox Text="{Binding TempSurname}" Classes="Input" Watermark="Иванов"/>
									</StackPanel>

									<StackPanel Grid.Column="1" Spacing="6">
										<TextBlock Text="Имя" Classes="FieldLabel" FontSize="12"/>
										<TextBox Text="{Binding TempName}" Classes="Input" Watermark="Иван"/>
									</StackPanel>

									<StackPanel Grid.Column="2" Spacing="6">
										<TextBlock Text="Отчество" Classes="FieldLabel" FontSize="12"/>
										<TextBox Text="{Binding TempMidname}" Classes="Input" Watermark="Иванович"/>
									</StackPanel>
								</Grid>

								<StackPanel Orientation="Horizontal" Spacing="10" Classes="FormActions">
									<Button Content="Сохранить"
											Classes="DialogAccent"
											Command="{Binding SaveProfileCommand}"
											Padding="20,8"/>
									<Button Content="Отмена"
											Classes="DialogOutline"
											Command="{Binding CancelEditProfileCommand}"
											Padding="16,8"/>
								</StackPanel>
							</StackPanel>
						</StackPanel>
					</Border>

					<Border Classes="Section">
						<StackPanel Spacing="16">

							<Grid ColumnDefinitions="Auto,*,Auto">
								<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
									<PathIcon Data="{StaticResource MentionIcon}"
											  Width="18" Height="18"
											  Foreground="{DynamicResource Accent}"/>
									<TextBlock Text="Имя пользователя"
											   Classes="SectionItemTitle"/>
								</StackPanel>

								<Button Grid.Column="2"
										Classes="IconButton Small"
										Command="{Binding StartEditUsernameCommand}"
										IsVisible="{Binding !IsEditingUsername}"
										ToolTip.Tip="Изменить">
									<PathIcon Data="{StaticResource EditIcon}"
											  Width="16" Height="16"
											  Foreground="{DynamicResource TextSecondary}"/>
								</Button>
							</Grid>

							<Grid ColumnDefinitions="90,*"
								  IsVisible="{Binding !IsEditingUsername}">
								<TextBlock Text="Username" Classes="FieldLabel" Opacity="0.7"/>
								<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
									<TextBlock Text="@" Classes="TextMuted" FontSize="14"/>
									<TextBlock Text="{Binding Username}" Classes="FieldValue"/>
								</StackPanel>
							</Grid>

							<StackPanel Spacing="14" IsVisible="{Binding IsEditingUsername}">
								<StackPanel Spacing="6">
									<TextBlock Text="Новый username" Classes="FieldLabel" FontSize="12"/>
									<Grid ColumnDefinitions="Auto,*">
										<Border Classes="InputPrefix">
											<TextBlock Text="@"
													   VerticalAlignment="Center"
													   FontSize="14"
													   Foreground="{DynamicResource TextMuted}"/>
										</Border>
										<TextBox Grid.Column="1"
												 Text="{Binding TempUsername}"
												 Classes="Input"
												 CornerRadius="0,8,8,0"
												 Watermark="username"
												 MaxLength="30"/>
									</Grid>

									<Panel Height="16">
										<TextBlock Text="{Binding UsernameValidationMessage}"
												   Classes="ValidationError"
												   IsVisible="{Binding UsernameValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
										<TextBlock Text="Латинские буквы, цифры и подчёркивания (3-30 символов)"
												   Classes="ValidationHint"
												   IsVisible="{Binding UsernameValidationMessage, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
									</Panel>
								</StackPanel>

								<StackPanel Orientation="Horizontal" Spacing="10" Classes="FormActions">
									<Button Content="Сохранить"
											Classes="DialogAccent"
											Command="{Binding SaveUsernameCommand}"
											IsEnabled="{Binding CanSaveUsername}"
											Padding="20,8"/>
									<Button Content="Отмена"
											Classes="DialogOutline"
											Command="{Binding CancelEditUsernameCommand}"
											Padding="16,8"/>
								</StackPanel>
							</StackPanel>
						</StackPanel>
					</Border>

					<Border Classes="Section">
						<StackPanel Spacing="16">
							<Grid ColumnDefinitions="Auto,*,Auto">
								<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
									<PathIcon Data="{StaticResource LockClosedIcon}"
											  Width="18" Height="18"
											  Foreground="{DynamicResource Accent}"/>
									<TextBlock Text="Безопасность"
											   Classes="SectionItemTitle"/>
								</StackPanel>

								<Button Grid.Column="2"
										Classes="IconButton Small"
										Command="{Binding StartEditPasswordCommand}"
										IsVisible="{Binding !IsEditingPassword}"
										ToolTip.Tip="Изменить пароль">
									<PathIcon Data="{StaticResource EditIcon}"
											  Width="16" Height="16"
											  Foreground="{DynamicResource TextSecondary}"/>
								</Button>
							</Grid>

							<Grid ColumnDefinitions="90,*"
								  IsVisible="{Binding !IsEditingPassword}">
								<TextBlock Text="Пароль" Classes="FieldLabel" Opacity="0.7"/>
								<TextBlock Grid.Column="1"
										   Text="••••••••••••"
										   Classes="FieldValue"
										   Foreground="{DynamicResource TextSecondary}"
										   LetterSpacing="2"/>
							</Grid>

							<StackPanel Spacing="16" IsVisible="{Binding IsEditingPassword}">

								<StackPanel Spacing="6">
									<TextBlock Text="Текущий пароль" Classes="FieldLabel" FontSize="12"/>
									<TextBox Text="{Binding CurrentPassword}"
											 Classes="Input"
											 PasswordChar="•"
											 Watermark="Введите текущий пароль"
											 MaxWidth="320"
											 HorizontalAlignment="Left"/>
								</StackPanel>

								<Separator Background="{DynamicResource BorderDefault}" Margin="0,4"/>

								<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
									<StackPanel Spacing="6">
										<TextBlock Text="Новый пароль" Classes="FieldLabel" FontSize="12"/>
										<TextBox Text="{Binding NewPassword}"
												 Classes="Input"
												 PasswordChar="•"
												 Watermark="Минимум 6 символов"/>
										<TextBlock Text="{Binding NewPasswordValidationMessage}"
												   Classes="ValidationHint"
												   IsVisible="{Binding NewPasswordValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
									</StackPanel>

									<StackPanel Grid.Column="1" Spacing="6">
										<TextBlock Text="Подтвердите пароль" Classes="FieldLabel" FontSize="12"/>
										<TextBox Text="{Binding ConfirmPassword}"
												 Classes="Input"
												 PasswordChar="•"
												 Watermark="Повторите пароль"/>

										<StackPanel Orientation="Horizontal"
													Spacing="5"
													Height="16"
													IsVisible="{Binding ShowPasswordMatchIndicator}">

											<StackPanel Orientation="Horizontal"
														Spacing="5"
														IsVisible="{Binding PasswordsMatch}">
												<PathIcon Data="{StaticResource CheckmarkIcon}"
														  Width="12" Height="12"
														  Foreground="{DynamicResource SuccessBrush}"/>
												<TextBlock Text="Пароли совпадают"
														   Classes="ValidationSuccess"/>
											</StackPanel>

											<StackPanel Orientation="Horizontal"
														Spacing="5"
														IsVisible="{Binding !PasswordsMatch}">
												<PathIcon Data="{StaticResource CloseIcon}"
														  Width="12" Height="12"
														  Foreground="{DynamicResource ErrorBrush}"/>
												<TextBlock Text="Пароли не совпадают"
														   Classes="ValidationError"/>
											</StackPanel>
										</StackPanel>
									</StackPanel>
								</Grid>

								<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0" Classes="FormActions">
									<Button Content="Изменить пароль"
											Classes="DialogAccent"
											Command="{Binding SavePasswordCommand}"
											IsEnabled="{Binding CanSavePassword}"
											Padding="20,8"/>
									<Button Content="Отмена"
											Classes="DialogOutline"
											Command="{Binding CancelEditPasswordCommand}"
											Padding="16,8"/>
								</StackPanel>
							</StackPanel>
						</StackPanel>
					</Border>

					<Border Classes="Section"
							IsVisible="{Binding HasDepartment}">
						<Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
							<PathIcon Data="{StaticResource OrganizationIcon}"
									  Width="18" Height="18"
									  Foreground="{DynamicResource Accent}"
									  VerticalAlignment="Center"/>
							<StackPanel Grid.Column="1" Spacing="2">
								<TextBlock Text="Отдел" Classes="TextSecondary" FontSize="12"/>
								<TextBlock Text="{Binding DepartmentDisplay}"
										   FontSize="14"
										   FontWeight="Medium"/>
							</StackPanel>
						</Grid>
					</Border>

					<Border Classes="Section">
						<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
							<PathIcon Data="{StaticResource SignOutIcon}"
									  Width="18" Height="18"
									  Foreground="{DynamicResource DangerBrush}"
									  VerticalAlignment="Center"/>
							<StackPanel Grid.Column="1"
										Spacing="2"
										VerticalAlignment="Center">
								<TextBlock Text="Выход из аккаунта"
										   FontSize="14"
										   FontWeight="Medium"/>
								<TextBlock Text="Вы будете перенаправлены на страницу входа"
										   Classes="TextMuted"
										   FontSize="12"/>
							</StackPanel>
							<Button Grid.Column="2"
									Content="Выйти"
									Classes="DialogDanger"
									Command="{Binding LogoutCommand}"
									VerticalAlignment="Center"
									Padding="20,8"/>
						</Grid>
					</Border>

					<Border Classes="AlertError"
							IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<PathIcon Data="{StaticResource WarningIcon}"
									  Width="18" Height="18"
									  Foreground="{DynamicResource ErrorBrush}"
									  VerticalAlignment="Center"/>
							<TextBlock Grid.Column="1"
									   Text="{Binding ErrorMessage}"
									   Foreground="{DynamicResource ErrorBrush}"
									   FontSize="13"
									   TextWrapping="Wrap"
									   Margin="10,0"/>
							<Button Grid.Column="2"
									Classes="IconButton Small"
									Command="{Binding ClearErrorCommand}"
									ToolTip.Tip="Закрыть">
								<PathIcon Data="{StaticResource CloseIcon}"
										  Width="14" Height="14"
										  Foreground="{DynamicResource ErrorBrush}"/>
							</Button>
						</Grid>
					</Border>

					<Border Classes="AlertSuccess"
							IsVisible="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<PathIcon Data="{StaticResource CheckmarkIcon}"
									  Width="18" Height="18"
									  Foreground="{DynamicResource SuccessBrush}"
									  VerticalAlignment="Center"/>
							<TextBlock Grid.Column="1"
									   Text="{Binding SuccessMessage}"
									   Foreground="{DynamicResource SuccessBrush}"
									   FontSize="13"
									   TextWrapping="Wrap"
									   Margin="10,0"/>
							<Button Grid.Column="2"
									Classes="IconButton Small"
									Command="{Binding ClearSuccessCommand}"
									ToolTip.Tip="Закрыть">
								<PathIcon Data="{StaticResource CloseIcon}"
										  Width="14" Height="14"
										  Foreground="{DynamicResource SuccessBrush}"/>
							</Button>
						</Grid>
					</Border>

				</StackPanel>
			</Border>
		</ScrollViewer>
	</Border>
</UserControl>