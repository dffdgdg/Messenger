<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmDialog="using:MessengerDesktop.ViewModels.Dialog"
             xmlns:conv="clr-namespace:MessengerDesktop.Converters;assembly=MessengerDesktop"
             xmlns:controls="using:MessengerDesktop.Views.Controls"
             x:Class="MessengerDesktop.Views.Dialog.UserPickerDialog"
             x:DataType="vmDialog:UserPickerDialogViewModel">
    <Border Classes="DialogContainer" Width="450" MaxHeight="650" Background="{DynamicResource SecondaryBG}">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Spacing="4">
                <Grid>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="20"/>
                    <!-- Счётчик только для multi-select -->
                    <TextBlock HorizontalAlignment="Right"
                               Text="{Binding SelectedCount, StringFormat='Выбрано: {0}'}"
                               Foreground="{DynamicResource TextSecondary}"
                               IsVisible="{Binding IsMultiSelect}"/>
                </Grid>
                <!-- Подсказка для single-select -->
                <TextBlock Text="Выберите пользователя из списка"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondary}"
                           IsVisible="{Binding !IsMultiSelect}"/>
            </StackPanel>

            <!-- Поиск -->
            <TextBox Grid.Row="1"
                     Text="{Binding SearchQuery}"
                     Watermark="Поиск по имени или логину..."
                     Classes="Input Search">
                <TextBox.InnerLeftContent>
                    <PathIcon Data="{StaticResource SearchIcon}"
                              Width="16" Height="16"
                              Margin="12,0,8,0"
                              Opacity="0.5"/>
                </TextBox.InnerLeftContent>
            </TextBox>

            <!-- Список пользователей -->
            <Border Grid.Row="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderDefault}"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Grid>
                    <!-- Пустое состояние -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="12"
                                IsVisible="{Binding !FilteredItems.Count}">
                        <PathIcon Data="{StaticResource PersonIcon}"
                                  Width="48" Height="48"
                                  Foreground="{DynamicResource TextMuted}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding EmptyMessage}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding FilteredItems.Count}">
                        <ItemsControl ItemsSource="{Binding FilteredItems}" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vmDialog:ChatEditDialogViewModel+SelectableUserItem">
                                    <Border Padding="10,8"
                                            Margin="0,2"
                                            CornerRadius="6"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            PointerPressed="OnUserItemPressed">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceHover}"/>
                                            </Style>
                                        </Border.Styles>

                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <!-- Чекбокс только для multi-select -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      Margin="0,0,12,0"
                                                      IsEnabled="{Binding $parent[UserControl].DataContext.AllowEdit}"
                                                      VerticalAlignment="Center"
                                                      IsVisible="{Binding $parent[UserControl].DataContext.IsMultiSelect}"/>

                                            <controls:AvatarControl Grid.Column="1"
                                                                    Size="36"
                                                                    Source="{Binding AvatarUrl}"
                                                                    DisplayName="{Binding DisplayName}"
                                                                    IsOnline="False"
                                                                    ShowOnlineIndicator="False"
                                                                    Margin="0,0,12,0"/>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Spacing="2">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="Medium"
                                                           FontSize="14"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Username}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Галочка для multi-select -->
                                            <Path Grid.Column="3"
                                                  Data="{StaticResource CheckIcon}"
                                                  Width="16" Height="16"
                                                  Fill="{DynamicResource AccentColor}"
                                                  VerticalAlignment="Center"
                                                  IsVisible="{Binding IsSelected}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Кнопки -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12"
                        Margin="0,12,0,0">
                <Button Content="Отмена"
                        Classes="DialogOutline"
                        Command="{Binding CancelCommand}"
                        MinWidth="100"/>
                <Button Content="Сохранить"
                        Classes="DialogAccent"
                        Command="{Binding SaveCommand}"
                        IsVisible="{Binding IsMultiSelect}"
                        MinWidth="100"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>