<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmDialog="using:MessengerDesktop.ViewModels.Dialog"
             xmlns:controls="using:MessengerDesktop.Views.Controls"
             xmlns:conv="clr-namespace:MessengerDesktop.Converters;assembly=MessengerDesktop"
             x:Class="MessengerDesktop.Views.Dialog.UserListDialog"
             x:DataType="vmDialog:UserListDialogViewModel">

    <Border Classes="DialogContainer" MaxHeight="680">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" RowSpacing="0">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,16">
                <Border Grid.Column="0" Classes="HeaderIconBadge" Margin="0,0,14,0">
                    <PathIcon Data="{StaticResource PersonIcon}"
                              Width="22" Height="22"
                              Foreground="{DynamicResource TextOnAccent}"/>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           Classes="DialogTitle Small"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="2"
                        Classes="CountBadge"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        IsVisible="{Binding IsEditMode}">
                    <TextBlock Text="{Binding SelectedCount, StringFormat='Выбрано: {0}'}"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>

                <Button Grid.Column="3"
                        Classes="IconButton"
                        Command="{Binding CancelCommand}"
                        ToolTip.Tip="Закрыть">
                    <PathIcon Data="{StaticResource CloseIcon}"
                              Width="14" Height="14"
                              Foreground="{DynamicResource TextSecondary}"/>
                </Button>
            </Grid>

            <Border Grid.Row="1" Classes="DialogDivider" Margin="-24,0,-24,16"/>

            <TextBox Grid.Row="2"
                     Text="{Binding SearchQuery}"
                     Watermark="Поиск по имени или логину..."
                     Classes="Input Search"
                     Margin="0,0,0,12">
                <TextBox.InnerLeftContent>
                    <PathIcon Data="{StaticResource SearchIcon}"
                              Classes="InputIcon"
                              Margin="12,0,8,0"/>
                </TextBox.InnerLeftContent>
            </TextBox>

            <Border Grid.Row="3"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderDefault}"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Grid>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="12"
                                IsVisible="{Binding !FilteredItems.Count}">
                        <PathIcon Data="{StaticResource PersonIcon}"
                                  Width="48" Height="48"
                                  Foreground="{DynamicResource TextMuted}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding EmptyMessage}"
                                   Classes="TextSecondary"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding FilteredItems.Count}">
                        <ItemsControl ItemsSource="{Binding FilteredItems}" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vmDialog:UserListItemViewModel">
                                    <Border Classes="PickerItem"
                                            PointerPressed="OnUserItemPressed">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                              ColumnSpacing="12">

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      IsEnabled="{Binding $parent[UserControl].DataContext.AllowEdit}"
                                                      VerticalAlignment="Center"
                                                      IsVisible="{Binding $parent[UserControl].DataContext.IsEditMode}"/>

                                            <controls:AvatarControl Grid.Column="1"
                                                                    Size="36"
                                                                    Source="{Binding AvatarUrl}"
                                                                    DisplayName="{Binding DisplayName}"
                                                                    IsOnline="False"
                                                                    ShowOnlineIndicator="False"/>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Spacing="2">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="Medium"
                                                           FontSize="14"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Username, StringFormat='@{0}'}"
                                                           FontSize="12"
                                                           Classes="TextSecondary"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <PathIcon Grid.Column="3"
                                                      Data="{StaticResource CheckmarkIcon}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource AccentBrush}"
                                                      VerticalAlignment="Center"
                                                      IsVisible="{Binding IsSelected}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="4" Classes="DialogDivider" Margin="-24,16,-24,16"/>

            <Grid Grid.Row="5" ColumnDefinitions="Auto,*,Auto,Auto">

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsEditMode}">
                    <PathIcon Data="{StaticResource EditIcon}"
                              Width="14" Height="14"
                              Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Text="Редактирование"
                               FontSize="12"
                               Classes="TextSecondary"/>
                </StackPanel>

                <Border Grid.Column="1"/>

                <Button Grid.Column="2"
                        Content="{Binding IsEditMode,
                        Converter={conv:Converter Name=BoolToString},
                        ConverterParameter='Назад|Отмена'}"
                        Classes="DialogOutline"
                        Command="{Binding CancelCommand}"
                        MinWidth="100"
                        Margin="0,0,12,0"/>

                <Panel Grid.Column="3" MinWidth="100">
                    <Button Classes="DialogAccent"
                            Command="{Binding BeginEditCommand}"
                            IsVisible="{Binding ShowEditButton}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource EditIcon}"
                                      Width="14" Height="14"
                                      Foreground="{DynamicResource TextOnAccent}"/>
                            <TextBlock Text="{Binding EditButtonText}"
                                       Foreground="{DynamicResource TextOnAccent}"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="DialogAccent"
                            Command="{Binding SaveCommand}"
                            IsVisible="{Binding ShowSaveButton}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource CheckmarkIcon}"
                                      Width="14" Height="14"
                                      Foreground="{DynamicResource TextOnAccent}"/>
                            <TextBlock Text="Сохранить"
                                       Foreground="{DynamicResource TextOnAccent}"/>
                        </StackPanel>
                    </Button>
                </Panel>
            </Grid>
        </Grid>
    </Border>
</UserControl>