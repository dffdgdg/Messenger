<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmDialog="using:MessengerDesktop.ViewModels.Dialog"
             xmlns:controls="using:MessengerDesktop.Views.Controls"
             xmlns:department="using:MessengerShared.Dto.Department"
             x:Class="MessengerDesktop.Views.DepartmentHeadDialog"
             x:DataType="vmDialog:DepartmentHeadDialogViewModel">

    <Border Classes="DialogContainer" Width="440">
        <StackPanel Spacing="20">

            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" Classes="HeaderIconBadge" Margin="0,0,14,0">
                    <PathIcon Data="{StaticResource OrganizationIcon}"
                              Width="22" Height="22"
                              Foreground="{DynamicResource TextOnAccent}"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Title}" Classes="DialogTitle Small"/>
                    <TextBlock Text="Отдел" Classes="DialogSubtitle" FontSize="12"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Classes="IconButton"
                        Command="{Binding CancelCommand}"
                        ToolTip.Tip="Закрыть">
                    <PathIcon Data="{StaticResource CloseIcon}"
                              Width="14" Height="14"
                              Foreground="{DynamicResource TextSecondary}"/>
                </Button>
            </Grid>

            <Border Classes="DialogDivider"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Название отдела" Classes="FieldLabel Secondary"/>
                <TextBox Text="{Binding Name}"
                         Classes="Input"
                         Watermark="Введите название отдела...">
                    <TextBox.InnerLeftContent>
                        <PathIcon Data="{StaticResource FolderIcon}"
                                  Classes="InputIcon"
                                  Margin="12,0,8,0"/>
                    </TextBox.InnerLeftContent>
                </TextBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Родительский отдел" Classes="FieldLabel Secondary"/>
                <ComboBox ItemsSource="{Binding AvailableParents}"
                          SelectedItem="{Binding SelectedParent}"
                          Classes="DialogCombo"
                          PlaceholderText="Выбрать родительский отдел"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="department:DepartmentDto">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource OrganizationIcon}"
                                          Width="14" Height="14"
                                          Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Руководитель отдела" Classes="FieldLabel Secondary"/>

                <Border Background="{DynamicResource SurfaceVariant}"
                        CornerRadius="10"
                        Padding="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource BorderDefault}">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <controls:AvatarControl Grid.Column="0"
                                                Classes="Small"
                                                Source="{Binding HeadAvatar}"
                                                DisplayName="{Binding HeadDisplayText}"
                                                IsVisible="{Binding HasHead}"
                                                Margin="0,0,12,0"/>

                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="18"
                                Background="{DynamicResource SurfaceBrush}"
                                IsVisible="{Binding !HasHead}"
                                Margin="0,0,12,0">
                            <PathIcon Data="{StaticResource PersonIcon}"
                                      Width="18" Height="18"
                                      Foreground="{DynamicResource TextTertiary}"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding HeadDisplayText}"
                                       FontSize="14"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Руководитель отдела"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextTertiary}"
                                       IsVisible="{Binding HasHead}"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Classes="IconButton Small"
                                Command="{Binding ClearHeadCommand}"
                                IsVisible="{Binding HasHead}"
                                ToolTip.Tip="Убрать руководителя"
                                Margin="8,0,4,0">
                            <PathIcon Data="{StaticResource CloseIcon}"
                                      Width="16" Height="16"
                                      Foreground="{DynamicResource DangerBrush}"/>
                        </Button>

                        <Button Grid.Column="3"
                                Classes="IconButton"
                                Command="{Binding SelectHeadCommand}"
                                ToolTip.Tip="Выбрать руководителя">
                            <PathIcon Data="{StaticResource AddIcon}"
                                      Width="18" Height="18"
                                      Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Classes="AlertInfo"
                    IsVisible="{Binding !IsNewDepartment}">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <PathIcon Grid.Column="0"
                                  Data="{StaticResource PersonIcon}"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource TextSecondary}"
                                  Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="Сотрудников в отделе"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding UserCount}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding HasChildren}">
                        <PathIcon Grid.Column="0"
                                  Data="{StaticResource WarningIcon}"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource WarningBrush}"
                                  Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="Имеет дочерние отделы"
                                   FontSize="12"
                                   Foreground="{DynamicResource WarningBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="AlertError"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Grid ColumnDefinitions="Auto,*">
                    <PathIcon Grid.Column="0"
                              Data="{StaticResource ErrorIcon}"
                              Width="16" Height="16"
                              Foreground="{DynamicResource DangerBrush}"
                              Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource DangerBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Border Classes="AlertSuccess"
                    IsVisible="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Grid ColumnDefinitions="Auto,*">
                    <PathIcon Grid.Column="0"
                              Data="{StaticResource CheckmarkIcon}"
                              Width="16" Height="16"
                              Foreground="{DynamicResource SuccessBrush}"
                              Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SuccessMessage}"
                               Foreground="{DynamicResource SuccessBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Border Classes="DialogDivider"/>

            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Button Grid.Column="0"
                        Classes="DialogDanger"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding !IsNewDepartment}"
                        IsEnabled="{Binding CanDelete}"
                        ToolTip.Tip="{Binding DeleteTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource DeleteIcon}"
                                  Width="14" Height="14"/>
                        <TextBlock Text="Удалить"/>
                    </StackPanel>
                </Button>

                <Border Grid.Column="1"/>

                <Button Grid.Column="2"
                        Content="Отмена"
                        Classes="DialogOutline"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                        Classes="DialogAccent"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource CheckmarkIcon}"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource TextOnAccent}"/>
                        <TextBlock Text="Сохранить"
                                   Foreground="{DynamicResource TextOnAccent}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>