<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:shared="using:MessengerDesktop.Views.Controls.Shared"
			 xmlns:parts="using:MessengerDesktop.Views.Chat.MessageParts.Shared"
			 xmlns:vmChat="using:MessengerDesktop.ViewModels.Chat"
			 x:Class="MessengerDesktop.Views.Chat.MessageParts.VoiceMessagePart"
			 x:DataType="vmChat:MessageViewModel"
			 x:Name="VoiceRoot">

	<Border Classes="VoicePlayerContainer"
			IsVisible="{Binding ShowVoiceMessage}">
		<StackPanel Spacing="0">

			<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">

				<Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoicePlayBtn"
						Width="46" Height="46"
						Command="{Binding PlayVoiceCommand}"
						IsVisible="{Binding ShowPlayButton}"
						ToolTip.Tip="Воспроизвести">
					<PathIcon Data="{StaticResource PlayIcon}" Width="20" Height="20"/>
				</Button>

				<Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoicePlayBtn"
						Width="46" Height="46"
						Command="{Binding PauseVoiceCommand}"
						IsVisible="{Binding ShowPauseButton}"
						ToolTip.Tip="Пауза">
					<PathIcon Data="{StaticResource PauseIcon}" Width="20" Height="20"/>
				</Button>

				<Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoicePlayBtn"
						Width="46" Height="46"
						Command="{Binding PlayVoiceCommand}"
						IsVisible="{Binding ShowResumeButton}"
						ToolTip.Tip="Продолжить">
					<PathIcon Data="{StaticResource PlayIcon}" Width="20" Height="20"/>
				</Button>

				<Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
						Classes="VoiceLoadingContainer"
						Width="46" Height="46"
						IsVisible="{Binding IsVoiceLoading}">
					<shared:CircularProgress Width="22" Height="22"
											 IsIndeterminate="True"
											 HorizontalAlignment="Center"
											 VerticalAlignment="Center"/>
				</Border>

				<Slider Grid.Row="0" Grid.Column="1"
						Classes="VoiceSlider"
						Value="{Binding VoicePositionPercent}"
						Margin="12,0,10,0"
						VerticalAlignment="Center"
						IsEnabled="{Binding IsVoicePlaying}"/>

				<Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
					  Margin="12,2,0,0">
					<Border HorizontalAlignment="Left" Classes="VoiceTimeBadge">
						<TextBlock Classes="VoiceTime">
							<TextBlock.Text>
								<MultiBinding StringFormat="{}{0} / {1}">
									<Binding Path="VoicePositionText"/>
									<Binding Path="VoiceDurationFormatted"/>
								</MultiBinding>
							</TextBlock.Text>
						</TextBlock>
					</Border>

					<StackPanel Orientation="Horizontal"
								Spacing="3"
								HorizontalAlignment="Right"
								VerticalAlignment="Center">
						<TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}"
								   FontSize="11"
								   Foreground="{DynamicResource TextMuted}"
								   VerticalAlignment="Bottom"
								   Margin="0,0,0,1"/>
						<Path Data="{StaticResource CheckIcon}"
							  Width="14" Height="14"
							  Stretch="Uniform"
							  VerticalAlignment="Bottom"
							  Margin="2,0,0,1"
							  Classes.Read="{Binding IsRead}"
							  Classes.Unread="{Binding !IsRead}"
							  IsVisible="{Binding ShowDeliveryStatus}">
							<Path.Styles>
								<Style Selector="Path.Read">
									<Setter Property="Fill" Value="{DynamicResource Accent}"/>
								</Style>
								<Style Selector="Path.Unread">
									<Setter Property="Fill" Value="{DynamicResource TextMuted}"/>
								</Style>
							</Path.Styles>
						</Path>
					</StackPanel>
				</Grid>
			</Grid>

			<TextBlock Text="{Binding VoiceError}"
					   Classes="VoiceError"
					   IsVisible="{Binding VoiceError,
					   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
		</StackPanel>
	</Border>		
</UserControl>