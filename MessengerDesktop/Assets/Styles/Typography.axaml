<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════
         ШРИФТЫ
         ══════════════════════════════════════════════════════════════ -->

    <Styles.Resources>
        <!-- Основной шрифт с кроссплатформенными fallback'ами -->
        <FontFamily x:Key="AppFontFamily">
            avares://MessengerDesktop/Assets/Fonts#Inter,
            Segoe UI,
            San Francisco,
            Ubuntu,
            Noto Sans,
            sans-serif
        </FontFamily>

        <!-- Моноширинный (для кода, если понадобится) -->
        <FontFamily x:Key="MonoFontFamily">
            JetBrains Mono,
            Cascadia Code,
            Consolas,
            Ubuntu Mono,
            monospace
        </FontFamily>
    </Styles.Resources>

    <!-- ═══ Глобальное применение ко всем контролам ═══ -->
 <!-- Все контролы с шаблонами (Button, TextBox, ListBox …) -->
<Style Selector=":is(TemplatedControl)">
    <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
    <Setter Property="FontSize"   Value="14" />
</Style>

<!-- TextBlock — отдельная ветка наследования -->
<Style Selector=":is(TextBlock)">
    <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
    <Setter Property="FontSize"   Value="14" />
</Style>

    <!-- ═══ Типографические масштабы ═══ -->

    <!-- Заголовок страницы: 28px (ваш PageTitle) -->
    <Style Selector="TextBlock.H1">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="36" />
    </Style>

    <!-- Заголовок панели: 18px (ваш PanelTitle) -->
    <Style Selector="TextBlock.H2">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="24" />
    </Style>

    <!-- Подзаголовок секции: 16px -->
    <Style Selector="TextBlock.H3">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="22" />
    </Style>

    <!-- Основной текст: 14px -->
    <Style Selector="TextBlock.Body">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <!-- Вторичный текст / превью: 13px -->
    <Style Selector="TextBlock.BodySmall">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <!-- Метки, время, категории: 12px -->
    <Style Selector="TextBlock.Caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="16" />
    </Style>

    <!-- Мелкий текст (бейджи, индикаторы): 11px -->
    <Style Selector="TextBlock.Micro">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="14" />
    </Style>

    <!-- Навигационные метки: 10px (ваш NavLabel) -->
    <Style Selector="TextBlock.NavLabel">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="12" />
    </Style>

    <!-- Код -->
    <Style Selector="TextBlock.Code">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

</Styles>